# Required for local development
NODE_ENV=development
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api
APP_SECRET_KEY=replace-with-32-byte-base64-or-hex-secret
OWNER_SESSION_SECRET=replace-with-long-random-secret
WEB_ORIGIN=http://localhost:3217

# Optional: where first-run owner setup writes the local password reminder.
# Defaults to OWNER_PASSWORD.local.md in the project root.
# OWNER_PASSWORD_NOTE_PATH=./OWNER_PASSWORD.local.md

# Postgres
DATABASE_URL=postgresql://review_pilot:review_pilot@localhost:5433/review_pilot

# Optional public deployment value.
# You can also set this from the Settings page.
PUBLIC_BASE_URL=https://reviews.example.com

# Redis / BullMQ
REDIS_URL=redis://localhost:6380

# Optional: automatic due Twilio notification scan.
# NOTIFICATION_SCHEDULER_ENABLED=true
# NOTIFICATION_WORKER_CONCURRENCY=2

# Optional: automatic Google review sync. The worker scans enabled locations hourly.
# REVIEW_SYNC_SCHEDULER_ENABLED=true
# New synced reviews automatically queue AI draft generation unless disabled.
# REVIEW_SYNC_AUTO_GENERATE_ENABLED=true

# Optional: Codex default model. The Settings page can override this.
# Codex home and runtime workdir are auto-detected by the API.
# CODEX_MODEL=gpt-5.4

# Railway deployment:
# - Set NEXT_PUBLIC_API_BASE_URL=/api on the web service.
# - Set API_PROXY_URL=http://api.railway.internal:4000 on the web service
#   after naming the API service "api" and setting API_PORT/PORT to 4000.
# - Attach a volume to worker if you want Codex ChatGPT auth to survive deploys.
#   Set the same CODEX_HOME/CODEX_WORKDIR strings on API and worker; only
#   worker needs the mounted volume because worker owns Codex execution.
# CODEX_HOME=/app/review-pilot-state/codex-home
# CODEX_WORKDIR=/app/review-pilot-state/codex-workdir
# OWNER_PASSWORD_NOTE_PATH=/app/review-pilot-state/OWNER_PASSWORD.local.md
